# Server environment variables

# Port to run the server on (default: 3003)
PORT=3003

# Node environment (development, production)
NODE_ENV=development

# Frontend URL for CORS (only needed in production)
# FRONTEND_URL=https://your-vercel-domain.vercel.app

# Secret key for signing session cookies (change this in production!)
SESSION_SECRET=change-me-in-production

# Optional: set to false to disable local default admin seeding
SEED_DEFAULT_ADMIN=true
