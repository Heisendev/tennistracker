# Frontend environment variables
# In production (Vercel), set this to /api — requests are proxied to Render via vercel.json
# In development, set this to http://localhost:3003
VITE_API_URL=http://localhost:3003

# Optional explicit WebSocket endpoint (recommended in production)
# Examples:
# - https://your-backend-url.com
# - wss://your-backend-url.com/live-updates
# VITE_WS_URL=https://your-backend-url.com
